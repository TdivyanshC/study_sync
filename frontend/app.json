{
  "expo": {
    "name": "Prodify",
    "slug": "prodify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prodify",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prodify.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "icon": "./assets/all-icons/iOS/Icon-1024.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/all-icons/Android/Icon-192.png",
        "backgroundColor": "#000000",
        "monochromeImage": "./assets/all-icons/Android/Icon-192.png"
      },
      "icon": "./assets/all-icons/Android/Icon-192.png",
      "statusBar": {
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "jsEngine": "hermes",
      "package": "com.prodify.app"
    },
    "macos": {
      "icon": "./assets/all-icons/macOS/Icon-1024.png"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/prodify.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000",
            "image": "./assets/images/prodify.png",
            "imageWidth": 300
          },
          "light": {
            "backgroundColor": "#000000",
            "image": "./assets/images/prodify.png",
            "imageWidth": 300
          }
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "",
          "androidClientId": "944168135230-i1dg2svf78c42i6ovmddarjvt7skcj9g.apps.googleusercontent.com",
          "webClientId": "944168135230-d85l1tlunaqumisao3iap07re4ir2gpk.apps.googleusercontent.com",
          "iosUrlScheme": "com.googleusercontent.apps.944168135230-d85l1tlunaqumisao3iap07re4ir2gpk"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      },
      "googleAndroidClientId": "944168135230-i1dg2svf78c42i6ovmddarjvt7skcj9g.apps.googleusercontent.com",
      "googleWebClientId": "944168135230-d85l1tlunaqumisao3iap07re4ir2gpk.apps.googleusercontent.com"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
